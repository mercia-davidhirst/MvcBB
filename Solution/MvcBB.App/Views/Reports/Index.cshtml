@model IEnumerable<ReportResponse>
@{
    ViewData["Title"] = "Reports";
    var currentStatus = ViewData["CurrentStatus"] as ReportStatus?;
}

<div class="container mt-4">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Filter Reports</h5>
                </div>
                <div class="list-group list-group-flush">
                    <a asp-action="Index" 
                       class="list-group-item list-group-item-action @(currentStatus == null ? "active" : "")">
                        All Reports
                    </a>
                    @foreach (ReportStatus status in Enum.GetValues(typeof(ReportStatus)))
                    {
                        <a asp-action="Index" asp-route-status="@status" 
                           class="list-group-item list-group-item-action @(currentStatus == status ? "active" : "")">
                            @status Reports
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Report List -->
        <div class="col-md-9">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Reports @(currentStatus != null ? $"- {currentStatus}" : "")</h5>
                </div>
                <div class="card-body">
                    @if (!Model.Any())
                    {
                        <p class="text-muted text-center my-4">No reports found.</p>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var report in Model)
                            {
                                <a asp-action="Details" asp-route-id="@report.Id" 
                                   class="list-group-item list-group-item-action">
                                    <div class="d-flex w-100 justify-content-between align-items-center">
                                        <h6 class="mb-1">
                                            @report.Type: @report.ContentTitle
                                            @if (report.Status == ReportStatus.Pending)
                                            {
                                                <span class="badge bg-warning">New</span>
                                            }
                                        </h6>
                                        <small class="text-muted">@report.CreatedAt.ToLocalTime().ToString("g")</small>
                                    </div>
                                    <p class="mb-1">
                                        <small>
                                            Reported by @report.ReporterUserId |
                                            Content by @report.ContentAuthorId |
                                            Status: <span class="badge bg-@GetStatusColor(report.Status)">@report.Status</span>
                                        </small>
                                    </p>
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
}

@functions {
    private string GetStatusColor(ReportStatus status) => status switch
    {
        ReportStatus.Pending => "warning",
        ReportStatus.Investigating => "info",
        ReportStatus.Resolved => "success",
        ReportStatus.Dismissed => "secondary",
        _ => "primary"
    };
} 