@model ReportResponse
@{
    ViewData["Title"] = $"Report #{Model.Id}";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Reports</a></li>
            <li class="breadcrumb-item active" aria-current="page">Report #@Model.Id</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Report Details -->
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header">
                    <h4 class="mb-0">Report Details</h4>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <h5>Reported Content</h5>
                        <dl class="row">
                            <dt class="col-sm-3">Type</dt>
                            <dd class="col-sm-9">@Model.Type</dd>

                            <dt class="col-sm-3">Content</dt>
                            <dd class="col-sm-9">
                                @switch (Model.Type)
                                {
                                    case ReportType.Thread:
                                        <a asp-controller="Threads" asp-action="Details" asp-route-id="@Model.ContentId">
                                            @Model.ContentTitle
                                        </a>
                                        break;
                                    case ReportType.Post:
                                        <a asp-controller="Threads" asp-action="Details" asp-route-id="@Model.ContentId">
                                            @Model.ContentTitle
                                        </a>
                                        break;
                                    case ReportType.Message:
                                        <a asp-controller="Messages" asp-action="Details" asp-route-id="@Model.ContentId">
                                            @Model.ContentTitle
                                        </a>
                                        break;
                                }
                            </dd>

                            <dt class="col-sm-3">Content Author</dt>
                            <dd class="col-sm-9">@Model.ContentAuthorId</dd>

                            <dt class="col-sm-3">Content Created</dt>
                            <dd class="col-sm-9">@Model.ContentCreatedAt.ToLocalTime().ToString("g")</dd>
                        </dl>
                    </div>

                    <div class="mb-4">
                        <h5>Report Information</h5>
                        <dl class="row">
                            <dt class="col-sm-3">Reported By</dt>
                            <dd class="col-sm-9">@Model.ReporterUserId</dd>

                            <dt class="col-sm-3">Reported At</dt>
                            <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("g")</dd>

                            <dt class="col-sm-3">Status</dt>
                            <dd class="col-sm-9">
                                <span class="badge bg-@GetStatusColor(Model.Status)">@Model.Status</span>
                            </dd>

                            <dt class="col-sm-3">Reason</dt>
                            <dd class="col-sm-9">@Model.Reason</dd>

                            @if (Model.ResolvedAt.HasValue)
                            {
                                <dt class="col-sm-3">Resolved By</dt>
                                <dd class="col-sm-9">@Model.ResolvedByUserId</dd>

                                <dt class="col-sm-3">Resolved At</dt>
                                <dd class="col-sm-9">@Model.ResolvedAt.Value.ToLocalTime().ToString("g")</dd>
                            }
                        </dl>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ModeratorNotes))
                    {
                        <div class="mb-4">
                            <h5>Moderator Notes</h5>
                            <div class="card bg-light">
                                <div class="card-body">
                                    @Model.ModeratorNotes
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Update Status -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Update Status</h5>
                </div>
                <div class="card-body">
                    <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">Status</label>
                            <select name="Status" class="form-select">
                                @foreach (ReportStatus status in Enum.GetValues(typeof(ReportStatus)))
                                {
                                    <option value="@status" selected="@(status == Model.Status)">@status</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Moderator Notes</label>
                            <textarea name="ModeratorNotes" class="form-control" rows="5">@Model.ModeratorNotes</textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Update Status</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
}

@functions {
    private string GetStatusColor(ReportStatus status) => status switch
    {
        ReportStatus.Pending => "warning",
        ReportStatus.Investigating => "info",
        ReportStatus.Resolved => "success",
        ReportStatus.Dismissed => "secondary",
        _ => "primary"
    };
} 