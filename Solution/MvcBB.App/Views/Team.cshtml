@using MvcBB.App.Interfaces
@model IEnumerable<MvcBB.Shared.Models.User.UserResponse>
@inject IUserService UserService

@{
    ViewData["Title"] = "Team";
}

<div class="container">
    <div class="row mb-4">
        <div class="col">
            <h1>Forum Team</h1>
            <p class="text-muted">Our administrators and moderators</p>
        </div>
    </div>

    <div class="row">
        <div class="col">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @if (!Model.Any())
            {
                <div class="alert alert-info">
                    No team members found.
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    @foreach (var user in Model)
                    {
                        <div class="col">
                            <div class="card h-100">
                                <div class="card-body">
                                    <div class="d-flex align-items-center mb-3">
                                        <i class="bi bi-person-circle fs-1 me-3"></i>
                                        <div>
                                            <h5 class="card-title mb-1">@user.Username</h5>
                                            @if (user.Role == MvcBB.Shared.Models.User.UserRole.Administrator)
                                            {
                                                <span class="badge bg-danger">Administrator</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">Moderator</span>
                                            }
                                        </div>
                                    </div>
                                    <p class="card-text">
                                        <small class="text-muted">Member since @user.CreatedAt.ToString("MMMM dd, yyyy")</small>
                                    </p>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <span class="badge bg-primary me-2" title="Threads">
                                                <i class="bi bi-chat-right-text"></i>
                                                @user.ThreadCount
                                            </span>
                                            <span class="badge bg-info" title="Posts">
                                                <i class="bi bi-chat-right"></i>
                                                @user.PostCount
                                            </span>
                                        </div>
                                        <div class="btn-group">
                                            <a asp-controller="Search" asp-action="Index" 
                                               asp-route-q="@user.Username"
                                               asp-route-type="threads"
                                               class="btn btn-sm btn-outline-primary"
                                               title="View threads by @user.Username">
                                                <i class="bi bi-chat-right-text"></i>
                                            </a>
                                            <a asp-controller="Search" asp-action="Index" 
                                               asp-route-q="@user.Username"
                                               asp-route-type="posts"
                                               class="btn btn-sm btn-outline-info"
                                               title="View posts by @user.Username">
                                                <i class="bi bi-chat-right"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
} 