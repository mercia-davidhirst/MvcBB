@using MvcBB.App.Models
@model SmilieViewModel
@{
    ViewData["Title"] = "Add Smilie";
    Layout = "_AdminLayout";
}

<div class="card">
    <div class="card-body">
        <form asp-action="AddSmilie" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Code" class="form-label"></label>
                <input asp-for="Code" class="form-control" />
                <span asp-validation-for="Code" class="text-danger"></span>
                <small class="form-text text-muted">The text code for the smilie (e.g., ":)", ":-)", etc.)</small>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
                <small class="form-text text-muted">A brief description of what this smilie represents</small>
            </div>

            <div class="mb-3">
                <label asp-for="ImageFile" class="form-label"></label>
                <input asp-for="ImageFile" class="form-control" type="file" accept="image/*" />
                <span asp-validation-for="ImageFile" class="text-danger"></span>
                <small class="form-text text-muted">The image file for the smilie (recommended size: 24x24 pixels)</small>
            </div>

            <div class="mb-3">
                <div class="form-check">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label"></label>
                </div>
                <small class="form-text text-muted">Whether this smilie is currently active</small>
            </div>

            <div class="mb-3">
                <label asp-for="SortOrder" class="form-label"></label>
                <input asp-for="SortOrder" class="form-control" type="number" />
                <span asp-validation-for="SortOrder" class="text-danger"></span>
                <small class="form-text text-muted">The order in which this smilie appears in lists (lower numbers first)</small>
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-action="Smilies" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
} 