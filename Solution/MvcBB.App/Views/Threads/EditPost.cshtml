@model UpdatePostRequest
@{
    ViewData["Title"] = "Edit Post";
    var post = ViewData["Post"] as Post;
    var threadTitle = ViewData["ThreadTitle"] as string;
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Boards" asp-action="Index">Boards</a></li>
            <li class="breadcrumb-item"><a asp-controller="Threads" asp-action="Details" asp-route-id="@post.ThreadId">@threadTitle</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit Post</li>
        </ol>
    </nav>

    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">Edit Post</h4>
        </div>
        <div class="card-body">
            <form asp-action="EditPost" asp-route-id="@post.Id" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Content" class="form-label">Content</label>
                    <textarea asp-for="Content" class="form-control" rows="10" required>@post.Content</textarea>
                    <span asp-validation-for="Content" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="EditReason" class="form-label">Edit Reason</label>
                    <input asp-for="EditReason" class="form-control" required />
                    <span asp-validation-for="EditReason" class="text-danger"></span>
                    <div class="form-text">Please provide a reason for editing this post.</div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Details" asp-route-id="@post.ThreadId" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
} 