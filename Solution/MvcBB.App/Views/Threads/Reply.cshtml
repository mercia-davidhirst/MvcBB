@using MvcBB.Shared.Interfaces
@model CreatePostRequest
@inject IBBCodeService BBCodeService
@{
    ViewData["Title"] = "Reply to Thread";
    var quotedPost = ViewData["QuotedPost"] as Post;
    var threadTitle = ViewData["ThreadTitle"] as string;
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Boards" asp-action="Index">Boards</a></li>
            <li class="breadcrumb-item"><a asp-controller="Threads" asp-action="Details" asp-route-id="@Model.ThreadId">@threadTitle</a></li>
            <li class="breadcrumb-item active" aria-current="page">Reply</li>
        </ol>
    </nav>

    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">Post Reply</h4>
        </div>
        <div class="card-body">
            @if (quotedPost != null)
            {
                <div class="quote-block mb-4 p-3 border-start border-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <small class="text-muted">@quotedPost.CreatedByUserId wrote:</small>
                        <small class="text-muted">@quotedPost.CreatedAt.ToLocalTime().ToString("g")</small>
                    </div>
                    <div class="quoted-content">@Html.Raw(BBCodeService.ParseBBCode(quotedPost.Content))</div>
                </div>
            }

            <form asp-action="CreatePost" asp-route-threadId="@Model.ThreadId" method="post">
                @Html.AntiForgeryToken()
                @if (quotedPost != null)
                {
                    <input type="hidden" name="QuotedPostId" value="@quotedPost.Id" />
                }
                <div class="form-group">
                    <label for="Content">Your Reply</label>
                    <partial name="_BBCodeToolbar" />
                    <textarea name="Content" id="Content" class="form-control" rows="10" required 
                              oninput="updatePreview()"></textarea>
                    
                    <div class="mt-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-2">Preview</h5>
                            <button type="button" class="btn btn-sm btn-outline-secondary" 
                                    onclick="togglePreview()">
                                <i class="bi bi-eye"></i> Toggle Preview
                            </button>
                        </div>
                        <div id="preview" class="bbcode-preview"></div>
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Post Reply</button>
                    <a asp-action="Details" asp-route-id="@Model.ThreadId" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
    <script>
        let previewVisible = true;

        function updatePreview() {
            if (!previewVisible) return;
            
            const content = document.getElementById('Content').value;
            fetch('/api/bbcode/preview', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ content })
            })
            .then(response => response.text())
            .then(html => {
                document.getElementById('preview').innerHTML = html;
            });
        }

        function togglePreview() {
            const preview = document.getElementById('preview');
            previewVisible = !previewVisible;
            if (previewVisible) {
                preview.style.display = 'block';
                updatePreview();
            } else {
                preview.style.display = 'none';
            }
        }

        // Initial preview
        updatePreview();
    </script>
} 