@using MvcBB.Shared.Interfaces
@model ThreadResponse
@inject IBBCodeService BBCodeService
@{
    ViewData["Title"] = Model.Title;
    var posts = (IEnumerable<PostResponse>)ViewData["Posts"];
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Boards" asp-action="Index">Boards</a></li>
            <li class="breadcrumb-item"><a asp-controller="Boards" asp-action="Details" asp-route-id="@Model.BoardId">@Model.BoardName</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
        </ol>
    </nav>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="mb-0">@Model.Title</h4>
            <div>
                @if (!Model.IsLocked || User.IsInRole("Administrator") || User.IsInRole("Moderator"))
                {
                    <a asp-action="Reply" asp-route-threadId="@Model.Id" class="btn btn-primary">Reply</a>
                }
                <a asp-controller="Reports" asp-action="Create" 
                   asp-route-type="Thread" asp-route-contentId="@Model.Id" 
                   class="btn btn-outline-warning">
                    <i class="bi bi-flag"></i> Report Thread
                </a>
            </div>
        </div>
    </div>

    @if (posts != null && posts.Any())
    {
        foreach (var post in posts)
        {
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <strong>@post.CreatedByUsername</strong>
                        <small class="text-muted">
                            posted @post.CreatedAt.ToString("g")
                            @if (post.IsEdited)
                            {
                                <span>(edited @post.UpdatedAt?.ToString("g"))</span>
                            }
                        </small>
                    </div>
                    <div>
                        @if (!Model.IsLocked || User.IsInRole("Administrator") || User.IsInRole("Moderator"))
                        {
                            <a asp-action="QuotePost" asp-route-threadId="@Model.Id" asp-route-postId="@post.Id" 
                               class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-quote"></i> Quote
                            </a>
                        }
                        <a asp-controller="Reports" asp-action="Create" 
                           asp-route-type="Post" asp-route-contentId="@post.Id"
                           class="btn btn-sm btn-outline-warning">
                            <i class="bi bi-flag"></i> Report
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (post.QuotedPost != null)
                    {
                        <blockquote class="blockquote mb-3">
                            <p class="mb-0">@Html.Raw(BBCodeService.ParseBBCode(post.QuotedPost.Content))</p>
                            <footer class="blockquote-footer">
                                <cite>@post.QuotedPost.CreatedByUsername</cite>
                            </footer>
                        </blockquote>
                    }
                    @Html.Raw(BBCodeService.ParseBBCode(post.Content))
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info">No posts found in this thread.</div>
    }

    @if (Model.IsLocked && !User.IsInRole("Administrator") && !User.IsInRole("Moderator"))
    {
        <div class="alert alert-warning">
            <i class="bi bi-lock-fill"></i> This thread is locked. New replies cannot be posted.
        </div>
    }
    else if (User.Identity?.IsAuthenticated == true)
    {
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Quick Reply</h5>
            </div>
            <div class="card-body">
                <form asp-action="CreatePost" asp-route-threadId="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <partial name="_BBCodeToolbar" />
                        <textarea name="Content" id="Content" class="form-control" rows="5" required 
                                  oninput="updatePreview()"></textarea>
                        
                        <div class="mt-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="mb-2">Preview</h5>
                                <button type="button" class="btn btn-sm btn-outline-secondary" 
                                        onclick="togglePreview()">
                                    <i class="bi bi-eye"></i> Toggle Preview
                                </button>
                            </div>
                            <div id="preview" class="bbcode-preview"></div>
                        </div>
                    </div>
                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary">Post Reply</button>
                    </div>
                </form>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Please <a asp-controller="Account" asp-action="Login">login</a> to post replies.
        </div>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
    <script>
        let previewVisible = true;

        function updatePreview() {
            if (!previewVisible) return;
            
            const content = document.getElementById('Content').value;
            fetch('/api/bbcode/preview', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ content })
            })
            .then(response => response.text())
            .then(html => {
                document.getElementById('preview').innerHTML = html;
            });
        }

        function togglePreview() {
            const preview = document.getElementById('preview');
            previewVisible = !previewVisible;
            if (previewVisible) {
                preview.style.display = 'block';
                updatePreview();
            } else {
                preview.style.display = 'none';
            }
        }

        // Initial preview
        updatePreview();
    </script>
} 