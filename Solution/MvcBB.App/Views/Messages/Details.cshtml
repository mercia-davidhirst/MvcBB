@model MessageResponse
@{
    ViewData["Title"] = Model.Subject;
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Messages</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Subject</li>
        </ol>
    </nav>

    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0">@Model.Subject</h4>
                <div>
                    <a asp-action="Create" asp-route-recipientId="@Model.SenderUserId" 
                       class="btn btn-primary btn-sm">
                        <i class="bi bi-reply"></i> Reply
                    </a>
                    <a asp-controller="Reports" asp-action="Create" 
                       asp-route-type="Message" asp-route-contentId="@Model.Id" 
                       class="btn btn-outline-warning btn-sm">
                        <i class="bi bi-flag"></i> Report
                    </a>
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm" 
                                onclick="return confirm('Are you sure you want to delete this message?')">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="message-meta mb-4">
                <div class="row">
                    <div class="col-md-6">
                        <strong>From:</strong> @Model.SenderUserId<br />
                        <strong>To:</strong> @Model.RecipientUserId
                    </div>
                    <div class="col-md-6 text-md-end">
                        <strong>Sent:</strong> @Model.CreatedAt.ToLocalTime().ToString("g")<br />
                        @if (Model.ReadAt.HasValue)
                        {
                            <strong>Read:</strong> @Model.ReadAt.Value.ToLocalTime().ToString("g")
                        }
                    </div>
                </div>
            </div>
            <div class="message-content">
                @Model.Content
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
} 