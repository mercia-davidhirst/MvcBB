@model IEnumerable<MessageResponse>
@{
    ViewData["Title"] = "Messages";
    var currentFolder = (string)ViewData["CurrentFolder"] ?? "inbox";
    var isInbox = currentFolder.Equals("inbox", StringComparison.OrdinalIgnoreCase);
}

<div class="container mt-4">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Messages</h5>
                </div>
                <div class="list-group list-group-flush">
                    <a asp-action="Create" class="list-group-item list-group-item-action">
                        <i class="bi bi-pencil-square"></i> New Message
                    </a>
                    <a asp-action="Index" asp-route-folder="inbox" 
                       class="list-group-item list-group-item-action @(isInbox ? "active" : "")">
                        <i class="bi bi-inbox"></i> Inbox
                    </a>
                    <a asp-action="Index" asp-route-folder="sent" 
                       class="list-group-item list-group-item-action @(!isInbox ? "active" : "")">
                        <i class="bi bi-send"></i> Sent
                    </a>
                </div>
            </div>
        </div>

        <!-- Message List -->
        <div class="col-md-9">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">@(isInbox ? "Inbox" : "Sent Messages")</h5>
                </div>
                <div class="card-body">
                    @if (!Model.Any())
                    {
                        <p class="text-muted text-center my-4">No messages found.</p>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var message in Model)
                            {
                                <a asp-action="Details" asp-route-id="@message.Id" 
                                   class="list-group-item list-group-item-action @(!message.IsRead && isInbox ? "fw-bold" : "")">
                                    <div class="d-flex w-100 justify-content-between align-items-center">
                                        <h6 class="mb-1">@message.Subject</h6>
                                        <small class="text-muted">@message.CreatedAt.ToLocalTime().ToString("g")</small>
                                    </div>
                                    <p class="mb-1">
                                        @if (isInbox)
                                        {
                                            <small>From: @message.SenderUserId</small>
                                        }
                                        else
                                        {
                                            <small>To: @message.RecipientUserId</small>
                                        }
                                    </p>
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
} 