@model BoardResponse

@{
    ViewData["Title"] = Model.Name;
}

<div class="container">
    <div class="row mb-4">
        <div class="col">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item"><a asp-action="Index">Boards</a></li>
                            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
                        </ol>
                    </nav>
                    <h1 class="mt-2">@Model.Name</h1>
                    <p class="text-muted">@Model.Description</p>
                </div>
                <div>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Threads" asp-action="Create" asp-route-boardId="@Model.Id" 
                           class="btn btn-primary">
                            <i class="bi bi-plus-circle"></i> New Thread
                        </a>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary ms-2">
                            <i class="bi bi-pencil"></i> Edit Board
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-9">
            @if (Model.ThreadCount == 0)
            {
                <div class="alert alert-info">
                    <p class="mb-0">No threads have been created in this board yet.</p>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <p class="mt-2 mb-0">
                            <a asp-controller="Threads" asp-action="Create" asp-route-boardId="@Model.Id">Create the first thread</a>
                        </p>
                    }
                    else
                    {
                        <p class="mt-2 mb-0">
                            Please <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path">login</a> 
                            or <a asp-controller="Account" asp-action="Register">register</a> to create a thread.
                        </p>
                    }
                </div>
            }
            else
            {
                <!-- Thread list will be rendered here by a partial view -->
                @await Component.InvokeAsync("ThreadList", new { boardId = Model.Id })
            }
        </div>

        <div class="col-md-3">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Board Statistics</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            Threads
                            <span class="badge bg-primary rounded-pill">@Model.ThreadCount</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            Posts
                            <span class="badge bg-primary rounded-pill">@Model.PostCount</span>
                        </li>
                    </ul>
                </div>
            </div>

            @if (Model.LastPostAt.HasValue)
            {
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Latest Activity</h5>
                    </div>
                    <div class="card-body">
                        <p class="mb-1">
                            <a asp-controller="Threads" asp-action="Details" asp-route-id="@Model.LastThreadId" 
                               class="text-decoration-none">
                                @Model.LastThreadTitle
                            </a>
                        </p>
                        <small class="text-muted">
                            by 
                            <a asp-controller="Account" asp-action="Profile" asp-route-username="@Model.LastPostByUsername" 
                               class="text-decoration-none">
                                @Model.LastPostByUsername
                            </a>
                            <br />
                            @Model.LastPostAt.Value.ToLocalTime().ToString("g")
                        </small>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
} 